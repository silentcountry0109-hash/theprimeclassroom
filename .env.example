# The Prime 質數教室 — 環境變數範本
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
#
# ⚠️  此檔案已加入 .gitignore，請勿將 .env 提交到 Git

# =============================================================================
# 資料庫
# =============================================================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/theprime

# =============================================================================
# Session 加密金鑰（隨機生成，建議 64 字元以上）
# 產生指令：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================================
SESSION_SECRET=your-super-secret-session-key-at-least-64-characters-long

# =============================================================================
# 應用程式設定
# =============================================================================
TZ=Asia/Taipei
NODE_ENV=development

# 正式環境才需要設定（production only）
# APP_BASE_URL=https://www.theprimeclassroom.com

# =============================================================================
# LINE 登入（家長端 OAuth）
# 取得：LINE Developers Console → LINE Login Channel
# Callback URL 設定為：https://你的網域/api/auth/line/callback
# =============================================================================
LINE_CHANNEL_ID=your-line-login-channel-id
LINE_CHANNEL_SECRET=your-line-login-channel-secret

# =============================================================================
# LINE Messaging API（客服訊息、官方帳號）
# 取得：LINE Developers Console → Messaging API Channel
# Webhook URL 設定為：https://你的網域/api/line/webhook
# =============================================================================
LINE_CHANNEL_ACCESS_TOKEN=your-line-messaging-access-token
LINE_MESSAGING_CHANNEL_SECRET=your-line-messaging-channel-secret
LINE_MESSAGING_CHANNEL_ID=2009852161

# =============================================================================
# 首頁「加入 LINE 好友」按鈕連結
# 格式：https://line.me/R/ti/p/@你的OA帳號ID
# =============================================================================
VITE_LINE_OA_URL=https://line.me/R/ti/p/@yourofficialaccountid

# =============================================================================
# 手機 OTP 驗證 — Twilio Verify（主要）
# 取得：https://console.twilio.com
# 服務類型：Verify Service（非 SMS API）
# =============================================================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# 手機 OTP 驗證 — 三竹簡訊 Mitake（備援，Twilio 失敗時自動切換）
# 取得：https://sms.mitake.com.tw
# =============================================================================
MITAKE_USERNAME=your-mitake-username
MITAKE_PASSWORD=your-mitake-password

# =============================================================================
# ECPay 綠界金流
# 測試環境（sandbox）直接使用以下預設值
# 正式上線時：換上正式金鑰，並將 ECPAY_IS_SANDBOX 改為 false
# ⚠️  ECPay Callback（POST /api/ecpay/notify）必須可被綠界伺服器訪問
# =============================================================================
ECPAY_MERCHANT_ID=2000132
ECPAY_HASH_KEY=5294y06JbISpM5x9
ECPAY_HASH_IV=v77hoKGq4kWxNNIS
ECPAY_IS_SANDBOX=true

# =============================================================================
# Google Gemini AI（老師大頭照 AI 生成）
# 取得：https://aistudio.google.com/app/apikey
# 使用模型：gemini-2.5-flash-image
# =============================================================================
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# Google Cloud Storage（圖片與 PDF 檔案儲存）
# 目前透過 Replit App Storage SDK 操作
# 離開 Replit 平台後需改用 @google-cloud/storage + Service Account
# =============================================================================
DEFAULT_OBJECT_STORAGE_BUCKET_ID=your-gcs-bucket-id
PUBLIC_OBJECT_SEARCH_PATHS=public
PRIVATE_OBJECT_DIR=.private
